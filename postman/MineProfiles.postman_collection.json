        "type": "text/javascript",
        "exec": [
          "pm.test('Status HTTP documentado', function () {",
          "  pm.expect([200, 201, 400, 404, 409, 422, 429, 500, 502]).to.include(pm.response.code);",
          "});",
          "pm.test('Resposta JSON valida', function () {",
          "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
